		<Description1>This device management object contains the elements of a nuSIM profile package according to nuSIM Technical Specification NTS.01.</Description1>
		<ObjectID>507</ObjectID>
		<ObjectURN>urn:oma:lwm2m:oma:507</ObjectURN>
		<LWM2MVersion>1.0</LWM2MVersion>
