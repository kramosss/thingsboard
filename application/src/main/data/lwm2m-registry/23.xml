<LWM2M xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.openmobilealliance.org/tech/profiles/LWM2M.xsd">
  <Object ObjectType="MODefinition">
		<Name>LwM2M COSE</Name>
		<Description1><![CDATA[This Object provides the keying material and related information for use with COSE.]]></Description1>
		<ObjectID>23</ObjectID>
		<ObjectURN>urn:oma:lwm2m:oma:23</ObjectURN>
    <LWM2MVersion>1.2</LWM2MVersion>
		<ObjectVersion>1.0</ObjectVersion>
    <MultipleInstances>Multiple</MultipleInstances>
		<Mandatory>Optional</Mandatory>
		<Resources>
			<Item ID="0"><Name>KID</Name>
				<Operations></Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>String</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[This resource is used to indicate the key identifier.]]></Description>
			</Item>
			<Item ID="1"><Name>AEAD Algorithm</Name>
				<Operations></Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[This resource is used to store the encoding of the AEAD Algorithm as defined in Table 10 of RFC 8152.]]></Description>
			</Item>
			<Item ID="2"><Name>Key</Name>
				<Operations></Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>String</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[This resource is used to store the key for use with the indicated AEAD algorithm.]]></Description>
			</Item></Resources>
			<Description2><![CDATA[]]></Description2>
	</Object>
</LWM2M>
