<!--
    SpotBugs exclusion filter.

    Patterns to suppress:
      - Generated protobuf / gRPC classes  (org.thingsboard.server.gen.*)
      - Generated telemetry plugin code
      - Test classes: analysed by Surefire/JaCoCo; SpotBugs false-positive rate
        is higher in test code and failures there should not block the build.
-->
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                            https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!-- ================================================================== -->
    <!-- Generated protobuf / gRPC sources                                  -->
    <!-- ================================================================== -->
    <Match>
        <Package name="~org\.thingsboard\.server\.gen(\..*)?" />
    </Match>

    <!-- ================================================================== -->
    <!-- Generated telemetry plugin proto sources                           -->
    <!-- ================================================================== -->
    <Match>
        <Package name="~org\.thingsboard\.server\.extensions\.core\.plugin\.telemetry\.gen(\..*)?" />
    </Match>

    <!-- ================================================================== -->
    <!-- Test classes                                                        -->
    <!-- ================================================================== -->
    <Match>
        <Class name="~.*Test(s)?" />
    </Match>
    <Match>
        <Class name="~.*IT" />
    </Match>

</FindBugsFilter>
